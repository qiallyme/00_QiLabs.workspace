{
  "continue_on_error": true,
  "scope": {
    "excluded_root_names": [
      "30_QiDrive",
      "90_QiArchive"
    ],
    "excluded_directory_names": [
      ".Encrypted",
      "backup",
      "backups",
      "backups_before_frontmatter",
      "legacy"
    ]
  },
  "cleanup": {
    "enabled": true,
    "directory_names": [
      "__pycache__",
      ".pytest_cache",
      ".mypy_cache",
      ".ruff_cache",
      ".parcel-cache",
      ".turbo",
      ".vite"
    ],
    "file_patterns": [
      "*.pyc",
      "*.pyo",
      ".DS_Store",
      "Thumbs.db",
      "npm-debug.log*",
      "yarn-debug.log*",
      "yarn-error.log*",
      "pnpm-debug.log*",
      ".eslintcache"
    ],
    "skip_traversal": [
      ".git",
      "node_modules",
      ".pnpm-store",
      ".yarn",
      "dist",
      "build",
      "coverage",
      ".venv",
      "venv"
    ],
    "prune_pnpm_store": true,
    "verify_npm_cache": true
  },
  "housekeeping": {
    "hooks": [
      {
        "name": "QiLabs Housekeeping Noninteractive",
        "enabled": false,
        "working_directory": "00_QiLabs.workspace\\toolbox\\checkers\\housekeeping_console",
        "command": "python",
        "arguments": [
          "housekeeping_console.py",
          "--apply-all",
          "--non-interactive"
        ]
      }
    ]
  },
  "node": {
    "default_manager": "npm",
    "prefer_lockfile_install": true,
    "allow_install_fallback": true,
    "build_script": "build"
  },
  "git": {
    "auto_commit": true,
    "push": true,
    "remote": "origin",
    "commit_message_template": "chore: automated QiLabs sync {timestamp}",
    "run_maintenance": true,
    "skip_repositories": [],
    "protected_file_patterns": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "*.p12",
      "*.pfx",
      "id_rsa*",
      "id_dsa*",
      "id_ed25519*",
      "*.kdbx",
      "*credentials.json",
      "*credentials.yaml",
      "*credentials.yml",
      "*secrets.json",
      "*secrets.yaml",
      "*secrets.yml",
      "*.sqlite",
      "*.sqlite3",
      "*.db"
    ]
  }
}